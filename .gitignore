# Dependencies & build
**/node_modules/
**/dist/
**/build/
**/.vite/

# Environment & secrets
*.pem
*.key
.env
.env.*
!.env.example
!frontend/.env.example

# OS
.DS_Store
Thumbs.db

# Editor / tool state
.claude/
.qodo/
.playwright-mcp/
.vscode/
.idea/
*.swp

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Office lock files
.~lock.*#

# Default-ignore markdown so transient notes don't sneak in.
# Documentation we DO want tracked is force-listed below.
*.md
!README.md
!VERIFICATION_REPORT.md
!docs/**/*.md
!frontend-v2/**/*.md
!scherzinger-platform/**/*.md

# Separate project (force-add tracked files inside)
scherzinger-platform/

# Legacy code with embedded API keys — rotate and delete
frontend/src_old/

# Root-level screenshots (all png/jpeg in repo root only).
# Subdir screenshots (e.g. docs/verification-screens/) are explicitly kept.
/*.png
/*.jpeg
/*.jpg

# Vendor / external reference binaries (PDFs, DOCX, XLSX, TEX)
# kept locally under reference/ but not tracked in git.
reference/

# Playwright cache
.playwright-mcp/

# Python build artefacts
**/__pycache__/
*.pyc

# Notebook checkpoints
**/.ipynb_checkpoints/

# Local response captures (Playwright debugging snapshots)
studio-response.json
snapshot-*.yml
forecasting-snapshot.yml
*.png
!docs/**/*.png
!notebooks/**/*.png
