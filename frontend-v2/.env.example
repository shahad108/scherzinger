# frontend-v2 environment variables
# Copy this to .env.local and fill in values for local dev. Do not commit .env.local.
#
# Full reference: ./docs/env.md

# Base URL for the Scherzinger BFF (screens layer). When unset, frontend-v2
# resolves all apiFetch calls from src/data/mocks/*.json instead.
# Example for local docker compose: http://localhost:8000/api/v1/screens
VITE_SCHERZINGER_API=

# API contract version pinned by this build. Changing this requires a coordinated
# backend rollout.
VITE_API_VERSION=v1

# When VITE_SCHERZINGER_API is set, set this to "1" to allow per-path fallback
# to bundled mocks on 404 / 503 / network error. MUST be unset (or "0") in
# production. Useful while the BFF is partial.
VITE_ALLOW_MOCK_FALLBACK=0

# Demo / staging fixture: which persona is auto-logged-in until real auth ships
# in Phase 2. One of: frank | till | heiko. Frank is the only persona with
# implemented screens.
VITE_DEFAULT_USER=frank

# Sentry DSN for client-side error reporting. Leave empty to disable.
VITE_SENTRY_DSN=

# Feature flag service URL (Unleash-compatible). Leave empty to fall back to
# the static feature list returned by /api/v1/me.
VITE_FEATURE_FLAGS_URL=
